{
  "framework": null,
  "buildCommand": "node scripts/build-prod.mjs",
  "outputDirectory": ".",
  "functions": {
    "api/upload.mjs": { "maxDuration": 300, "memory": 1024 },
    "api/study/generate.mjs": { "maxDuration": 120, "memory": 1024 },
    "api/questions/generate-solution.mjs": { "maxDuration": 90, "memory": 1024 },
    "api/questions/enhance-solution.mjs": { "maxDuration": 60, "memory": 1024 },
    "api/exams/generate-solutions.mjs": { "maxDuration": 120, "memory": 1024 },
    "api/exams/reverify-answers.mjs": { "maxDuration": 120, "memory": 512 },
    "api/crud.mjs": { "maxDuration": 60, "memory": 512 },
    "api/questions/ai-action.mjs": { "maxDuration": 180, "memory": 1024 }
  },
  "rewrites": [
    { "source": "/api/questions/:questionId/reanalyze", "destination": "/api/questions/ai-action" },
    { "source": "/api/questions/:questionId/regenerate-answer", "destination": "/api/questions/ai-action" },
    { "source": "/api/questions/:questionId/recrop", "destination": "/api/questions/ai-action" },
    { "source": "/api/exams/:examId/context", "destination": "/api/crud" },
    { "source": "/api/exams/:examId/context/:groupId", "destination": "/api/crud" },
    { "source": "/api/exams/finalize-review", "destination": "/api/crud" },
    { "source": "/api/upload-sign", "destination": "/api/crud" },
    { "source": "/api/me", "destination": "/api/crud" },
    { "source": "/api/courses", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/courses", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/exams", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/questions", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/review-queue", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/exams/:examId", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/questions/:questionId", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/trash", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/trash/:action", "destination": "/api/crud" },
    { "source": "/api/attempt", "destination": "/api/crud" },
    { "source": "/api/batches/start", "destination": "/api/crud" },
    { "source": "/api/batches/end", "destination": "/api/crud" },
    { "source": "/api/courses/:courseId/batches", "destination": "/api/crud" },
    { "source": "/api/health", "destination": "/api/crud" },
    { "source": "/api/study/packs", "destination": "/api/crud" },
    { "source": "/api/study/packs/:id", "destination": "/api/crud" },
    { "source": "/api/admin/switch-plan", "destination": "/api/crud" },
    { "source": "/api/account/delete", "destination": "/api/crud" },
    { "source": "/api/ai/generate-similar", "destination": "/api/crud" },
    { "source": "/api/ai/extract-topics", "destination": "/api/crud" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/login", "destination": "/public/index.html" },
    { "source": "/dashboard", "destination": "/public/index.html" },
    { "source": "/pricing", "destination": "/public/index.html" },
    { "source": "/quiz", "destination": "/public/index.html" },
    { "source": "/summary", "destination": "/public/index.html" },
    { "source": "/review", "destination": "/public/index.html" },
    { "source": "/insights", "destination": "/public/index.html" },
    { "source": "/lab", "destination": "/public/index.html" },
    { "source": "/progress", "destination": "/public/index.html" },
    { "source": "/courses/(.*)", "destination": "/public/index.html" },
    { "source": "/degree/(.*)", "destination": "/public/index.html" },
    { "source": "/legal/terms.html", "destination": "/public/legal/terms.html" },
    { "source": "/legal/privacy.html", "destination": "/public/legal/privacy.html" },
    { "source": "/legal/cookies.html", "destination": "/public/legal/cookies.html" },
    { "source": "/vocab", "destination": "/vocab/index.html" },
    { "source": "/vocab/", "destination": "/vocab/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; img-src 'self' data: blob: https://*.supabase.co https://res.cloudinary.com https://images.unsplash.com https://placehold.co; script-src 'self' 'unsafe-inline' https://esm.sh https://cdn.esm.sh https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' https://*.supabase.co https://esm.sh https://cdn.esm.sh https://api.cloudinary.com https://res.cloudinary.com https://cdn.jsdelivr.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; manifest-src 'self'; worker-src 'self' blob: https://cdn.jsdelivr.net" }
      ]
    },
    {
      "source": "/public/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/public/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/public/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/public/data/(.*).json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/vocab/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
